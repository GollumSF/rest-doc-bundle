{
    "name": "gollumsf/rest-doc-bundle",
    "type": "symfony-bundle",
    "description": "Auto-Generate documentation API for GollumSF\\RestBundle",
    "keywords" : [
        "api",
        "documentation",
        "swagger",
        "openapi",
        "rest",
        "gollumsf"
    ],
    "homepage": "https://github.com/GollumSF/rest-doc-bundle",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Damien Duboeuf",
            "email": "smeagolworms4@gmail.com"
        }
    ],
    "support" : {
        "email": "smeagolworms4@gmail.com",
        "wiki": "https://github.com/GollumSF/rest-doc-bundle/blob/master/README.md"
    },
    "require" : {
        "php": ">=8.2",
        "gollumsf/rest-bundle": "^2.8.1|^3.0",
        "gollumsf/controller-action-extractor-bundle": "^1.0|^2.0",
        "symfony/twig-bundle": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "gollumsf/reflection-property-test": "^1.0",
        "matthiasnoback/symfony-dependency-injection-test": "^4.1|^5.0|^6.0|^7.0",
        "nyholm/symfony-bundle-test": "^3.0",
        "doctrine/annotations": "^1.0|^2.0"
    },
    "autoload" : {
        "psr-4" : {
            "GollumSF\\RestDocBundle\\" : "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\GollumSF\\RestDocBundle\\" : "tests/"
        }
    }
}
